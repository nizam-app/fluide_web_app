# Flunexia web app — Vite environment
# Copy this file to `.env.local` (or `.env`) for local development.

# Base URL of the Flunexia backend API. Defaults to localhost:5000 when unset.
# Local API:
VITE_API_URL=http://localhost:5000/api/v1

# Production API (set in Vercel → Environment Variables):
# VITE_API_URL=https://fluenixa-backend.onrender.com/api/v1
